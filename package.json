{
  "name": "extract-email",
  "version": "3.0.1-alpha",
  "description": "CLI tool to extract and process emails from IMAP accounts with support for multiple account configurations and custom task plugins.",
  "author": "John Haugabook",
  "publisher": "isocialPractice",
  "type": "module",
  "main": "dist/extractEmail.js",
  "bin": {
    "extractEmail": "./dist/extractEmail.js"
  },
  "files": [
    "dist/",
    "helpers/",
    "extractEmailTasks/downloadAttachments.js.template",
    "extractEmailTasks/stop.js.template",
    "extractEmailTasks/verbose.js.template",
    "accounts/example.mjs.template",
    "configEmailExtraction.mjs.template",
    "config.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "icon.png"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "node dist/extractEmail.js",
    "test": "node test/run-tests.mjs"
  },
  "keywords": [
    "email",
    "imap",
    "cli",
    "extract",
    "mail",
    "parser"
  ],
  "license": "ISC",
  "dependencies": {
    "@jhauga/getdate": "^1.0.1",
    "html-to-text": "^9.0.5",
    "htmlparser2": "^9.1.0",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.9.3"
  }
}
